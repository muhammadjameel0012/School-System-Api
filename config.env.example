# Server
PORT=8000
NODE_ENV=development

# JWT (required for login/signup and protected routes)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES=7d

# Database (optional – app may use default local MongoDB)
# DATABASE_URL=mongodb://localhost:27017/your-db-name

# Email – only if using nodemailer (e.g. password reset)
# GOOGLE_EMAIL=your-email@gmail.com
# GOOGLE_PASS_KEY=your-app-password
